      "element_gap": "gap-6 md:gap-8"
    },
    "visual_enhancers": {
      "radius": "rounded-xl",
      "shadows": {
        "card": "shadow-[0_2px_8px_rgba(0,0,0,0.08)] hover:shadow-[0_8px_24px_rgba(0,0,0,0.12)] transition-shadow duration-300",
        "button": "shadow-md hover:shadow-lg"
      },
      "glassmorphism": "bg-white/80 backdrop-blur-md border border-white/20",
      "gradients": {
        "hero_overlay": "bg-gradient-to-r from-stone-50/90 to-stone-50/40",
        "primary_button": "bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800"
      }
    }
  },
