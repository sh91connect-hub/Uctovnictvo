  "instructions_to_main_agent": {
    "general": "Build a single-page React app. Use 'react-scroll' for navigation. Ensure mobile responsiveness is perfect.",
    "styling": "Use Tailwind CSS for all styling. Avoid inline styles. Use the defined color palette.",
    "components": "Use Shadcn UI for Accordion (FAQ), Tabs (Pricing), and Form elements. Customize them to match the Emerald/Gold theme.",
