{
  "design_system": {
    "typography": {
      "font_family": {
        "heading": "Outfit, sans-serif",
        "body": "Plus Jakarta Sans, sans-serif"
      },
      "scale": {
        "h1": "text-5xl md:text-6xl font-bold tracking-tight",
        "h2": "text-3xl md:text-4xl font-semibold tracking-tight",
        "h3": "text-2xl font-semibold",
        "body": "text-base md:text-lg leading-relaxed text-slate-600",
        "small": "text-sm font-medium text-slate-500"
      }
    },
    "colors": {
      "theme": "light",
      "palette": {
        "primary": {
          "DEFAULT": "#047857",
          "foreground": "#FFFFFF",
          "hover": "#065F46"
        },
        "secondary": {
          "DEFAULT": "#D97706",
          "foreground": "#FFFFFF",
          "hover": "#B45309"
        },
        "background": {
          "DEFAULT": "#FAFAF9",
          "paper": "#FFFFFF",
          "subtle": "#F5F5F4"
        },
        "text": {
          "primary": "#0F172A",
          "secondary": "#475569",
          "muted": "#94A3B8"
        },
        "border": {
          "DEFAULT": "#E2E8F0",
          "focus": "#047857"
        }
      }
